// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  PROFESSOR
}

enum ExamStatus {
  PENDING
  ONGOING
  COMPLETED
}

enum StressLevel {
  BASELINE
  MILD_STRESS
  HIGH_STRESS
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(PROFESSOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  professor Professor?
}

model Student {
  id           Int          @id @default(autoincrement())
  firstName    String
  lastName     String
  email        String       @unique
  department   String
  studentCode  String       @unique
  braceletId   String?      @unique
  heartRate    Int?
  stressScore  Float?
  stressLevel  StressLevel?
  connected    Boolean      @default(false)
  lastUpdate   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  examStudents     ExamStudent[]
  telemetryHistory TelemetryHistory[]
}

model Professor {
  id         Int      @id @default(autoincrement())
  firstName  String
  lastName   String
  email      String   @unique
  department String
  userId     Int      @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  exams      Exam[]
}

model Classroom {
  id        Int      @id @default(autoincrement())
  name      String
  building  String
  capacity  Int
  rows      Int
  columns   Int

  tables    Table[]
  exams     Exam[]
}

model Table {
  id          Int       @id @default(autoincrement())
  classroomId Int
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  qrCode      String?   @db.Text
  positionX   Int
  positionY   Int

  examStudents ExamStudent[]
}

model Exam {
  id          Int        @id @default(autoincrement())
  title       String
  module      String
  examDate    DateTime
  startTime   DateTime
  endTime     DateTime
  classroomId Int
  classroom   Classroom  @relation(fields: [classroomId], references: [id])
  professorId Int
  professor   Professor  @relation(fields: [professorId], references: [id])
  status      ExamStatus @default(PENDING)

  examStudents       ExamStudent[]
  monitoringSessions MonitoringSession[]
}

model ExamStudent {
  id        Int     @id @default(autoincrement())
  examId    Int
  exam      Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId Int
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tableId   Int
  table     Table   @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId])
  @@unique([examId, tableId])
}

model MonitoringSession {
  id        Int       @id @default(autoincrement())
  examId    Int
  exam      Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  active    Boolean   @default(true)

  telemetryHistory TelemetryHistory[]
}

model TelemetryHistory {
  id           Int               @id @default(autoincrement())
  studentId    Int
  student      Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sessionId    Int
  session      MonitoringSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  braceletId   String
  heartRate    Int
  stressScore  Float
  stressLevel  StressLevel
  timestamp    DateTime          @default(now())
}
